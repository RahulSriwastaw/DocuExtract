# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="your_app_url_here"

# AIRTABLE_API_KEY: Your Airtable Personal Access Token (PAT).
# Required scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_API_KEY="your_airtable_api_key_here"

# AIRTABLE_BASE_ID: Your Airtable Base ID (found in the API documentation for your base).
AIRTABLE_BASE_ID="your_airtable_base_id_here"

# SUPABASE_URL: Your Supabase project URL.
SUPABASE_URL="your_supabase_url_here"

# SUPABASE_ANON_KEY: Your Supabase anonymous key.
SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# DATABASE_URL: Your PostgreSQL connection string for Supabase.
DATABASE_URL="your_database_url_here"

# OPENROUTER_API_KEY: Your OpenRouter API key for accessing multiple AI models.
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# GROQ_API_KEY: Your Groq API key for fast AI inference.
GROQ_API_KEY="your_groq_api_key_here"

# DEFAULT_AI_PROVIDER: Default AI provider to use (gemini, openrouter, groq)
DEFAULT_AI_PROVIDER="gemini"