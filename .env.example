# NVIDIA_API_KEY: Required for NVIDIA NIM API calls.
# Get your API key from https://build.nvidia.com
NVIDIA_API_KEY="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"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AIRTABLE_API_KEY: Your Airtable Personal Access Token (PAT).
# Required scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_API_KEY=""

# AIRTABLE_BASE_ID: Your Airtable Base ID (found in the API documentation for your base).
AIRTABLE_BASE_ID=""
