# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AIRTABLE_API_KEY: Your Airtable Personal Access Token (PAT).
# Required scopes: data.records:read, data.records:write, schema.bases:read, schema.bases:write
AIRTABLE_API_KEY=""

# AIRTABLE_BASE_ID: Your Airtable Base ID (found in the API documentation for your base).
AIRTABLE_BASE_ID=""

# OPENROUTER_API_KEY: Required for OpenRouter AI calls.
OPENROUTER_API_KEY=""

# GROQ_API_KEY: Required for Groq AI calls.
GROQ_API_KEY=""

# MODAL_API_KEY: Required for Modal AI calls.
MODAL_API_KEY=""

# SUPABASE_URL: Your Supabase project URL.
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase anonymous key.
SUPABASE_ANON_KEY=""

# DATABASE_URL: Your Supabase PostgreSQL connection string.
DATABASE_URL=""

# SUPABASE_SERVICE_ROLE_KEY: Optional server-side service role key.
SUPABASE_SERVICE_ROLE_KEY=""
